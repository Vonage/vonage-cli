{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@vonage/cli",
  "version": "3.1.0",
  "description": "Vonage CLI",
  "license": "Apache 2.0",
  "contributors": [
    {
      "name": "Paul Ardeleanu",
      "url": "https://github.com/pardel"
    },
    {
      "name": "Chuck \"MANCHUCK\" Reeves",
      "url": "https://github.com/manchuck"
    },
    {
      "name": "Chris Tankersley",
      "url": "https://github.com/dragonmantank"
    }
  ],
  "type": "module",
  "bin": {
    "vonage": "bin/vonage.js"
  },
  "files": [
    "src/**",
    "bin/**",
    "data/**"
  ],
  "scripts": {
    "eslint": "eslint",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "husky",
    "test": "node --test --import ./__tests__/setup.js",
    "test:watch": "node --test --watch --import ./__tests__/setup.js",
    "test:coverage": "node --test --import ./__tests__/setup.js --experimental-test-coverage --test-reporter=junit --test-reporter-destination=junit.xml --test-reporter=spec --test-reporter-destination=stdout"
  },
  "lint-staged": {
    "package.json": [
      "npx sort-package-json"
    ],
    "*.js": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@laboralphy/did-you-mean": "3.1.0",
    "@stoplight/prism-cli": "5.15.11",
    "@vonage/auth": "1.15.0",
    "@vonage/conversations": "1.14.0",
    "@vonage/jwt": "1.14.0",
    "@vonage/server-client": "1.20.0",
    "@vonage/server-sdk": "3.27.0",
    "ajv": "8.20.0",
    "camelcase": "9.0.0",
    "chalk": "5.6.2",
    "compare-versions": "6.1.1",
    "deepmerge": "4.3.1",
    "json-diff": "1.0.6",
    "jsonwebtoken": "9.0.3",
    "ngrok": "5.0.0-beta.2",
    "node-fetch": "3.3.2",
    "snakecase": "1.0.0",
    "table": "6.9.0",
    "winston": "3.19.0",
    "yaml": "2.9.0",
    "yargs": "18.0.0",
    "yargs-parser": "22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.5.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "c8": "11.0.0",
    "eslint-plugin-n": "18.2.2",
    "esmock": "2.7.6",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "winston-transport": "4.9.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
